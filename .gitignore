# ── Build output ──────────────────────────────────────────────────────────────
/build/

# ── Compiled binaries ─────────────────────────────────────────────────────────
*.3dsx
*.cia
*.elf
*.smdh
*.dol
*.gcm
*.iso
*.sav
*.exe
*.out
*.bin
*.o
*.a

# ── Generated atlas (regenerated by tools/gen_atlas.py) ───────────────────────
data/textures/atlas.png
include/atlas_regions.h

# ── Embedded data (generated by bin2s / bin2cpp.py) ───────────────────────────
build/
*.s

# ── Credentials / secrets ─────────────────────────────────────────────────────
.git-credentials
*.pem
*.key

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor files ──────────────────────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
*.suo
*.user
*.ncb
*.sdf

# ── VS Code (keep c_cpp_properties.json, ignore workspace settings) ────────────
.vscode/*
!.vscode/c_cpp_properties.json

# ── DevKitPro / MSYS2 temp ────────────────────────────────────────────────────
*.dep
*.d
*.stackdump
*.map

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.tmp